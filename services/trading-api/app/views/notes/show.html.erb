<% content_for :title, "#{@trader[:name]}'s #{@ticker} Notes · The Tiverton House" %>

<style>
  nav {
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-gold);
    padding: 1rem 2rem;
  }

  .nav-content {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-logo {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.3rem;
    color: var(--accent-cream);
    text-decoration: none;
    letter-spacing: 1px;
  }

  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
  }

  .nav-link:hover { color: var(--accent-gold); }

  .content {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
  }

  .header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 3px solid var(--accent-gold);
  }

  .header-info h1 {
    font-family: 'Libre Baskerville', serif;
    font-size: 2rem;
    color: var(--accent-gold);
  }

  .header-info p {
    color: var(--text-muted);
    font-style: italic;
  }

  .notes-content {
    background: var(--bg-secondary);
    border: 1px solid var(--border-gold);
    border-radius: 8px;
    padding: 2rem;
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 16px;
    line-height: 1.8;
  }

  .notes-content h1, .notes-content h2, .notes-content h3 {
    font-family: 'Libre Baskerville', serif;
    color: var(--accent-gold);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .notes-content h1 { font-size: 1.6rem; }
  .notes-content h2 { font-size: 1.3rem; }
  .notes-content h3 { font-size: 1.1rem; }

  .notes-content p { margin-bottom: 1rem; }
  .notes-content ul, .notes-content ol { margin: 1rem 0 1rem 2rem; }
  .notes-content li { margin-bottom: 0.5rem; }

  .notes-content strong { color: var(--accent-cream); }
  .notes-content em { color: var(--text-secondary); }

  .notes-content code {
    background: var(--bg-tertiary);
    padding: 0.2rem 0.4rem;
    border-radius: 3px;
    font-family: monospace;
  }

  .notes-content blockquote {
    border-left: 3px solid var(--accent-gold);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .links {
    margin-top: 2rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .link-btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--bg-tertiary);
    border: 1px solid var(--border-gold);
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 6px;
    transition: all 0.2s;
  }

  .link-btn:hover {
    border-color: var(--accent-gold);
    color: var(--accent-gold);
  }

  footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-gold);
    padding: 2rem;
    text-align: center;
    color: var(--text-muted);
    margin-top: 3rem;
  }
</style>

<nav>
  <div class="nav-content">
    <%= link_to "Tiverton House", root_path, class: "nav-logo" %>
    <%= link_to "← Dashboard", root_path, class: "nav-link" %>
  </div>
</nav>

<div class="content">
  <div class="header">
    <%= image_tag @trader[:image], alt: @trader[:name], class: "avatar" %>
    <div class="header-info">
      <h1><%= @trader[:name] %> on <%= @ticker %></h1>
      <p><%= @trader[:role] %></p>
    </div>
  </div>

  <% if @error %>
    <div class="notes-content"><p style="color: var(--text-muted);"><%= @error %></p></div>
  <% else %>
    <div class="notes-content"><%= markdown(@content) %></div>
  <% end %>

  <div class="links">
    <%= link_to "← #{@trader[:name]}'s Profile", trader_path(@trader[:id]), class: "link-btn" %>
    <%= link_to "#{@ticker} Research →", research_path(@ticker), class: "link-btn" %>
  </div>
</div>

<footer>
  <p>The Tiverton House</p>
</footer>

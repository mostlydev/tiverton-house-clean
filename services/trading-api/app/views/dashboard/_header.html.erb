<%
  checks = Array(health[:checks])
  error_count = checks.count { |check| check[:status] == "error" }
  warning_count = checks.count { |check| check[:status] == "warning" }
  health_class =
    if error_count.positive?
      "error"
    elsif warning_count.positive?
      "warning"
    else
      "ok"
    end
%>

<div class="header">
  <div class="header-left">
    <h1>Tiverton <span class="brand-accent">House</span></h1>
    <div id="status-badges" class="header-status-badges">
      <% checks.each do |check| %>
        <span class="status-badge <%= check[:status] %>" title="<%= check[:name] %>: <%= check[:message] %>"></span>
      <% end %>
    </div>
    <div class="health-summary <%= health_class %>">
      <% if error_count.positive? %>
        <%= pluralize(error_count, "critical") %>
      <% elsif warning_count.positive? %>
        <%= pluralize(warning_count, "warning") %>
      <% else %>
        All systems nominal
      <% end %>
    </div>
  </div>
  <div class="header-right">
    <div class="nav-links">
      <%= link_to "Dashboard", root_path, class: "nav-link" %>
      <%= link_to "System Docs", "/docs/system.html", class: "nav-link", target: "_blank" %>
      <a href="https://github.com/mostlydev/tiverton-trades" class="github-link" target="_blank" title="Public Audit Trail">
        <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        Audit
      </a>
    </div>
    <div id="market-status">
      <% status_class = market_status[:status].downcase.gsub('_', '-') %>
      <span class="market-badge <%= status_class %>"><%= market_status[:status] %></span>
    </div>
  </div>
</div>

<div class="tiverton-hero">
  <%= link_to trader_path("tiverton"), class: "tiverton-avatar-link" do %>
    <%= image_tag "tiverton.png", class: "tiverton-avatar", alt: "Lord Tiverton" %>
  <% end %>
  <div class="tiverton-info">
    <h2 class="tiverton-title">Lord Tiverton</h2>

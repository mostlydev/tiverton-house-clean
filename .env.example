ALPACA_DATA_ENDPOINT=https://data.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
FINANCIAL_DATASETS_API_KEY=

# Discord server wiring
DISCORD_GUILD_ID=
